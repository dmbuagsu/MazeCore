<Page x:Class="MazeCore.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource SettingsTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">
            <StackPanel>
                <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,10,0,25" Foreground="{DynamicResource AppForeground}"/>

                <TextBlock Text="{DynamicResource ThemeLabel}" Margin="0,0,0,5" Foreground="{DynamicResource SubtleText}" FontSize="14"/>
                <ComboBox x:Name="ThemeComboBox" Height="38" Margin="0,0,0,15" Style="{StaticResource ThemedComboBoxStyle}">
                    <ComboBoxItem Content="{DynamicResource LightThemeOption}" Tag="Light"/>
                    <ComboBoxItem Content="{DynamicResource DarkThemeOption}" Tag="Dark"/>
                </ComboBox>

                <TextBlock Text="{DynamicResource LanguageLabel}" Margin="0,0,0,5" Foreground="{DynamicResource SubtleText}" FontSize="14"/>
                <ComboBox x:Name="LanguageComboBox" Height="38" Margin="0,0,0,25" Style="{StaticResource ThemedComboBoxStyle}">
                    <ComboBoxItem Content="Українська" Tag="uk"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                </ComboBox>

                <Button Content="{DynamicResource BtnSaveSettings}" Height="45" Margin="0,5,0,15" 
                        Style="{StaticResource PrimaryButtonStyle}" Click="SaveSettingsButton_Click"/>

                <Button Content="{DynamicResource BtnBack}" Height="30" Margin="0,0,0,5" 
                        Style="{StaticResource LinkButtonStyle}" Click="BackButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
