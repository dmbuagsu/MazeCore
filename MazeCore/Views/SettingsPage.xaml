<Page x:Class="MazeCore.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource SettingsTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Border Style="{StaticResource CardStyle}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="360">
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="{DynamicResource SettingsTitle}"
                           FontSize="26" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"
                           Foreground="{DynamicResource AppForeground}"/>

                <!-- Вибір теми -->
                <TextBlock Text="{DynamicResource ThemeLabel}"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource SubtleText}"
                           FontSize="13"/>
                <ComboBox x:Name="ThemeComboBox"
                          Height="42"
                          Margin="0,0,0,20"
                          Style="{StaticResource ThemedComboBoxStyle}">
                    <ComboBoxItem Content="{DynamicResource LightThemeOption}" Tag="Light"/>
                    <ComboBoxItem Content="{DynamicResource DarkThemeOption}"  Tag="Dark"/>
                </ComboBox>

                <!-- Вибір мови -->
                <TextBlock Text="{DynamicResource LanguageLabel}"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource SubtleText}"
                           FontSize="13"/>
                <ComboBox x:Name="LanguageComboBox"
                          Height="42"
                          Margin="0,0,0,28"
                          Style="{StaticResource ThemedComboBoxStyle}">
                    <ComboBoxItem Content="Українська" Tag="uk"/>
                    <ComboBoxItem Content="English"    Tag="en"/>
                </ComboBox>

                <!-- Зберегти -->
                <Button Content="{DynamicResource BtnSaveSettings}"
                        Height="46"
                        Margin="0,0,0,14"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SaveSettingsButton_Click"/>

                <!-- Назад -->
                <Button Content="{DynamicResource BtnBack}"
                        Height="30"
                        Style="{StaticResource LinkButtonStyle}"
                        Click="BackButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
