<Page x:Class="MazeCore.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource LoginTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="320">
            <StackPanel>
                <TextBlock Text="{DynamicResource AppTitle}" FontSize="32" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,10,0,25" Foreground="{DynamicResource AppForeground}"/>

                <TextBlock Text="{DynamicResource LoginLabel}" Margin="0,0,0,5" Foreground="{DynamicResource SubtleText}" FontSize="14"/>
                <TextBox x:Name="LoginTextBox" Height="38" Margin="0,0,0,15" Style="{StaticResource ThemedTextBoxStyle}"/>

                <TextBlock Text="{DynamicResource PasswordLabel}" Margin="0,0,0,5" Foreground="{DynamicResource SubtleText}" FontSize="14"/>
                <PasswordBox x:Name="LoginPasswordBox" Height="38" Margin="0,0,0,15" Style="{StaticResource ThemedPasswordBoxStyle}"/>

                <TextBlock x:Name="ErrorTextBlock" Foreground="{DynamicResource DangerColor}" FontSize="13" 
                           HorizontalAlignment="Center" Margin="0,0,0,15" 
                           Visibility="Collapsed" TextWrapping="Wrap"/>

                <Button Content="{DynamicResource BtnSignIn}" Height="45" Margin="0,5,0,15" 
                        Style="{StaticResource PrimaryButtonStyle}" Click="LoginButton_Click"/>

                <Button Content="{DynamicResource BtnGoToRegister}" Height="30" Margin="0,0,0,5" 
                        Style="{StaticResource LinkButtonStyle}" Click="RegisterButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>