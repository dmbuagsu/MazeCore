<Page x:Class="MazeCore.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource LoginTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Border Style="{StaticResource CardStyle}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="340">
            <StackPanel>
                <!-- Назва додатку -->
                <TextBlock Text="{DynamicResource AppTitle}"
                           FontSize="30" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"
                           Foreground="{DynamicResource AccentColor}"/>

                <TextBlock Text="{DynamicResource LoginTitle}"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"
                           Foreground="{DynamicResource SubtleText}"/>

                <!-- Поле логіну -->
                <TextBlock Text="{DynamicResource LoginLabel}"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource SubtleText}"
                           FontSize="13"/>
                <TextBox x:Name="LoginTextBox"
                         Height="42"
                         Margin="0,0,0,16"
                         Style="{StaticResource ThemedTextBoxStyle}"/>

                <!-- Поле пароля -->
                <TextBlock Text="{DynamicResource PasswordLabel}"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource SubtleText}"
                           FontSize="13"/>
                <PasswordBox x:Name="LoginPasswordBox"
                             Height="42"
                             Margin="0,0,0,16"
                             Style="{StaticResource ThemedPasswordBoxStyle}"/>

                <!-- Блок помилки -->
                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="{StaticResource DangerColor}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Кнопка входу -->
                <Button Content="{DynamicResource BtnSignIn}"
                        Height="46"
                        Margin="0,0,0,14"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="LoginButton_Click"/>

                <!-- Посилання на реєстрацію -->
                <Button Content="{DynamicResource BtnGoToRegister}"
                        Height="30"
                        Style="{StaticResource LinkButtonStyle}"
                        Click="RegisterButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>