<Page x:Class="MazeCore.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизація">

    <Grid Background="#F0F2F5">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300" 
                    Background="White" Margin="20">
            <StackPanel.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </StackPanel.Effect>

            <TextBlock Text="MazeCore" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,20,0,20" Foreground="#333"/>

            <TextBlock Text="Логін:" Margin="20,0,20,5" Foreground="#666"/>
            <TextBox x:Name="LoginTextBox" Height="35" Margin="20,0,20,15" Padding="5" 
                     FontSize="14" BorderBrush="#CCC"/>

            <TextBlock Text="Пароль:" Margin="20,0,20,5" Foreground="#666"/>
            <PasswordBox x:Name="LoginPasswordBox" Height="35" Margin="20,0,20,5" Padding="5" 
                         FontSize="14" BorderBrush="#CCC"/>

            <TextBlock x:Name="ErrorTextBlock" Foreground="Red" FontSize="12" 
                       HorizontalAlignment="Center" Margin="20,0,20,10" 
                       Visibility="Collapsed" TextWrapping="Wrap"/>

            <Button Content="УВІЙТИ" Height="40" Margin="20,10,20,10" 
                    Style="{StaticResource PrimaryButtonStyle}" Click="LoginButton_Click"/>

            <Button Content="Створити акаунт" Height="30" Margin="20,0,20,20" 
                    Background="Transparent" Foreground="#0078D7" BorderThickness="0" 
                    Cursor="Hand" Click="RegisterButton_Click"/>
        </StackPanel>
    </Grid>
</Page>