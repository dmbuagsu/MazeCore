<Window x:Class="MazeCore.Views.RenameMazeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Перейменування / Rename"
        Width="400" Height="185"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource RenameDialogLabel}"
                   Foreground="{DynamicResource SubtleText}"
                   FontSize="13"/>

        <TextBox Grid.Row="2"
                 x:Name="NameTextBox"
                 Height="40"
                 Style="{StaticResource ThemedTextBoxStyle}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource BtnCancel}"
                    Width="100" Height="38" Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click"/>
            <Button Content="{DynamicResource BtnSave}"
                    Width="100" Height="38"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
