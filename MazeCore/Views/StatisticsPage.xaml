<Page x:Class="MazeCore.Views.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource StatsTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="10,10,10,0" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource StatsTitle}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppForeground}" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" x:Name="SearchTextBox" Width="150" Height="35" Margin="0,0,10,0" Style="{StaticResource ThemedTextBoxStyle}"/>
                <Button Grid.Column="2" Content="{DynamicResource BtnSearch}" Style="{StaticResource PrimaryButtonStyle}" Width="80" Height="35" Margin="0,0,10,0" Click="SearchButton_Click"/>

                <Button Grid.Column="3" Content="{DynamicResource BtnSort}" Style="{StaticResource PrimaryButtonStyle}" 
                        Width="120" Height="35" Margin="0,0,10,0" Click="SortButton_Click"/>

                <!-- Кнопки для Update та Delete операцій -->
                <Button Grid.Column="4" Content="{DynamicResource BtnRenameMaze}" Style="{StaticResource PrimaryButtonStyle}" 
                        Width="120" Height="35" Margin="0,0,10,0" Click="RenameButton_Click"/>

                <Button Grid.Column="5" Content="{DynamicResource BtnDeleteMaze}" Style="{StaticResource DangerButtonStyle}" 
                        Width="100" Height="35" Margin="0,0,10,0" Click="DeleteButton_Click"/>

                <Button Grid.Column="6" Content="{DynamicResource BtnRefresh}" Style="{StaticResource PrimaryButtonStyle}" 
                        Background="#F39C12" Width="90" Height="35" Margin="0,0,10,0" Click="RefreshButton_Click"/>

                <Button Grid.Column="7" Content="{DynamicResource BtnBack}" Style="{StaticResource LinkButtonStyle}" 
                        Width="60" Height="35" Click="BackButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="10" Padding="10">
            <DataGrid x:Name="MazesDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                      RowBackground="{DynamicResource DataGridRow}" AlternatingRowBackground="{DynamicResource DataGridAltRow}"
                      Foreground="{DynamicResource AppForeground}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Назва / Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Ширина / Width" Binding="{Binding Width}" Width="80"/>
                    <DataGridTextColumn Header="Висота / Height" Binding="{Binding Height}" Width="80"/>
                    <DataGridTextColumn Header="Створено ким / Creator" Binding="{Binding CreatorName}" Width="150"/>
                    <DataGridTextColumn Header="Дата / Date" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>