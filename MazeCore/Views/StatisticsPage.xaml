<Page x:Class="MazeCore.Views.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Статистика та База лабіринтів">

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Margin="10,10,10,0" CornerRadius="8" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="База збережених лабіринтів" FontSize="20" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1" x:Name="SearchTextBox" Width="150" Height="35" Margin="0,0,10,0" Padding="5" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="Пошук" Style="{StaticResource PrimaryButtonStyle}" Width="80" Height="35" Margin="0,0,10,0" Click="SearchButton_Click"/>

                <Button Grid.Column="3" Content="Сортувати (QuickSort)" Style="{StaticResource PrimaryButtonStyle}" 
            Width="180" Height="35" Margin="0,0,10,0" Click="SortButton_Click"/>

                <Button Grid.Column="4" Content="Оновити" Style="{StaticResource PrimaryButtonStyle}" 
            Background="#F39C12" Width="100" Height="35" Margin="0,0,10,0" Click="RefreshButton_Click"/>

                <Button Grid.Column="5" Content="Назад" Background="Transparent" Foreground="#0078D7" 
            BorderThickness="0" Cursor="Hand" Click="BackButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="10" CornerRadius="8" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>

            <DataGrid x:Name="MazesDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      HeadersVisibility="Column" Background="White" BorderThickness="0"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEE">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Ширина" Binding="{Binding Width}" Width="80"/>
                    <DataGridTextColumn Header="Висота" Binding="{Binding Height}" Width="80"/>
                    <DataGridTextColumn Header="Створено ким" Binding="{Binding CreatorName}" Width="150"/>
                    <DataGridTextColumn Header="Дата створення" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>