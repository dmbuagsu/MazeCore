<Page x:Class="MazeCore.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource AppTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{DynamicResource AppTitle}" FontSize="56" FontWeight="Bold" 
                       Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="{DynamicResource WelcomeSubtitle}" FontSize="18" 
                       Foreground="{DynamicResource SubtleText}" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <Button Content="{DynamicResource BtnLogin}" Width="250" Height="45" Margin="0,0,0,15"
                    Style="{StaticResource PrimaryButtonStyle}" Click="GoToLogin_Click"/>

            <Button Content="{DynamicResource BtnCreateAccount}" Width="250" Height="45" 
                    Style="{StaticResource PrimaryButtonStyle}" Click="GoToRegister_Click"/>
        </StackPanel>
    </Grid>
</Page>