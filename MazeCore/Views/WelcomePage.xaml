<Page x:Class="MazeCore.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ласкаво просимо">

    <Grid Background="#2F3640">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="MazeCore" FontSize="48" FontWeight="Bold" 
                       Foreground="#00A8FF" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Генератор та вирішувач лабіринтів" FontSize="18" 
                       Foreground="#F5F6FA" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <Button Content="УВІЙТИ В СИСТЕМУ" Width="250" Height="45" Margin="0,0,0,15"
                    Style="{StaticResource PrimaryButtonStyle}" Click="GoToLogin_Click"/>

            <Button Content="СТВОРИТИ АКАУНТ" Width="250" Height="45" 
                    Style="{StaticResource PrimaryButtonStyle}" Background="#4CD137" Click="GoToRegister_Click"/>
        </StackPanel>
    </Grid>
</Page>