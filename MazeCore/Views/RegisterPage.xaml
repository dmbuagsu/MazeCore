<Page x:Class="MazeCore.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource RegisterTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Border Style="{StaticResource CardStyle}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="360">
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="{DynamicResource RegisterTitle}"
                           FontSize="26" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"
                           Foreground="{DynamicResource AppForeground}"/>

                <!-- Повне ім'я -->
                <TextBlock Text="{DynamicResource FullNameLabel}"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource SubtleText}"
                           FontSize="13"/>
                <TextBox x:Name="FullNameTextBox"
                         Height="42"
                         Margin="0,0,0,14"
                         Style="{StaticResource ThemedTextBoxStyle}"/>

                <!-- Логін -->
                <TextBlock Text="{DynamicResource LoginInputLabel}"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource SubtleText}"
                           FontSize="13"/>
                <TextBox x:Name="LoginTextBox"
                         Height="42"
                         Margin="0,0,0,14"
                         Style="{StaticResource ThemedTextBoxStyle}"/>

                <!-- Пароль -->
                <TextBlock Text="{DynamicResource PasswordInputLabel}"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource SubtleText}"
                           FontSize="13"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="42"
                             Margin="0,0,0,14"
                             Style="{StaticResource ThemedPasswordBoxStyle}"/>

                <!-- Підтвердження пароля -->
                <TextBlock Text="{DynamicResource ConfirmPasswordLabel}"
                           Margin="0,0,0,5"
                           Foreground="{DynamicResource SubtleText}"
                           FontSize="13"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Height="42"
                             Margin="0,0,0,16"
                             Style="{StaticResource ThemedPasswordBoxStyle}"/>

                <!-- Блок помилки -->
                <TextBlock x:Name="ErrorTextBlock"
                           Foreground="{StaticResource DangerColor}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Кнопка реєстрації -->
                <Button Content="{DynamicResource BtnSignUp}"
                        Height="46"
                        Margin="0,0,0,14"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="RegisterButton_Click"/>

                <!-- Повернутися до входу -->
                <Button Content="{DynamicResource BtnBackToLogin}"
                        Height="30"
                        Style="{StaticResource LinkButtonStyle}"
                        Click="BackToLoginButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>