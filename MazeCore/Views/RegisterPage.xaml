<Page x:Class="MazeCore.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource RegisterTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Border Style="{StaticResource CardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">
            <StackPanel>
                <TextBlock Text="{DynamicResource RegisterTitle}" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,5,0,20" Foreground="{DynamicResource AppForeground}"/>

                <TextBlock Text="{DynamicResource FullNameLabel}" Margin="0,0,0,5" Foreground="{DynamicResource SubtleText}" FontSize="14"/>
                <TextBox x:Name="FullNameTextBox" Height="38" Margin="0,0,0,10" Style="{StaticResource ThemedTextBoxStyle}"/>

                <TextBlock Text="{DynamicResource LoginInputLabel}" Margin="0,0,0,5" Foreground="{DynamicResource SubtleText}" FontSize="14"/>
                <TextBox x:Name="LoginTextBox" Height="38" Margin="0,0,0,10" Style="{StaticResource ThemedTextBoxStyle}"/>

                <TextBlock Text="{DynamicResource PasswordInputLabel}" Margin="0,0,0,5" Foreground="{DynamicResource SubtleText}" FontSize="14"/>
                <PasswordBox x:Name="PasswordBox" Height="38" Margin="0,0,0,10" Style="{StaticResource ThemedPasswordBoxStyle}"/>

                <TextBlock Text="{DynamicResource ConfirmPasswordLabel}" Margin="0,0,0,5" Foreground="{DynamicResource SubtleText}" FontSize="14"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Height="38" Margin="0,0,0,15" Style="{StaticResource ThemedPasswordBoxStyle}"/>

                <TextBlock x:Name="ErrorTextBlock" Foreground="{DynamicResource DangerColor}" FontSize="13" 
                           HorizontalAlignment="Center" Margin="0,0,0,15" 
                           Visibility="Collapsed" TextWrapping="Wrap"/>

                <Button Content="{DynamicResource BtnSignUp}" Height="45" Margin="0,5,0,15" 
                        Style="{StaticResource PrimaryButtonStyle}" Click="RegisterButton_Click"/>

                <Button Content="{DynamicResource BtnBackToLogin}" Height="30" Margin="0,0,0,5" 
                        Style="{StaticResource LinkButtonStyle}" Click="BackToLoginButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>