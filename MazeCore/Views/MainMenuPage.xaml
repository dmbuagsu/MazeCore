<Page x:Class="MazeCore.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource MainMenuTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,40,0,20">
            <TextBlock Text="{DynamicResource AppTitle}" FontSize="42" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="{DynamicResource AppForeground}"/>
            <TextBlock x:Name="WelcomeTextBlock" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{DynamicResource AccentColor}" Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="280">
            <Button Content="{DynamicResource BtnPlay}" Style="{StaticResource PrimaryButtonStyle}" Height="45" Margin="0,0,0,15" Click="GoToGame_Click" />

            <Button x:Name="AdminEditorButton" Content="{DynamicResource BtnEditor}" Style="{StaticResource PrimaryButtonStyle}" Height="45" Margin="0,0,0,15" Click="GoToEditor_Click"/>

            <Button Content="{DynamicResource BtnStats}" Style="{StaticResource PrimaryButtonStyle}" Height="45" Margin="0,0,0,15" Click="GoToStats_Click"/>

            <Button Content="{DynamicResource BtnSettings}" Style="{StaticResource PrimaryButtonStyle}" Height="45" Margin="0,0,0,30" Click="GoToSettings_Click"/>

            <Button Content="{DynamicResource BtnLogout}" Style="{StaticResource DangerButtonStyle}" Height="45" Click="LogoutButton_Click"/>
        </StackPanel>
    </Grid>
</Page>