<Page x:Class="MazeCore.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Головне меню">
    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="MazeCore" FontSize="36" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,40,0,20" Foreground="#2F3640"/>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="250">
            <Button Content="Генерувати лабіринт" Height="45" Margin="0,0,0,15" />
            <Button Content="Редактор (Admin)" Height="45" Margin="0,0,0,15"/>
            <Button Content="Статистика" Height="45" Margin="0,0,0,15"/>
            <Button Content="Вихід" Height="45" />
        </StackPanel>
    </Grid>
</Page>