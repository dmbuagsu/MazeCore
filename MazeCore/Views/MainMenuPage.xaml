<Page x:Class="MazeCore.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Головне меню">

    <Grid Background="#F5F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,40,0,20">
            <TextBlock Text="MazeCore" FontSize="36" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="#2F3640"/>
            <TextBlock x:Name="WelcomeTextBlock" FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="#0078D7" Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="250">
            <Button Content="Грати (Генератор)" Style="{StaticResource PrimaryButtonStyle}" Height="45" Margin="0,0,0,15" Click="GoToGame_Click" />

            <Button x:Name="AdminEditorButton" Content="Редактор (Admin)" Style="{StaticResource PrimaryButtonStyle}" Height="45" Margin="0,0,0,15" Click="GoToEditor_Click"/>

            <Button Content="Статистика" Style="{StaticResource PrimaryButtonStyle}" Height="45" Margin="0,0,0,15" Click="GoToStats_Click"/>

            <Button Content="Вихід" Style="{StaticResource PrimaryButtonStyle}" Background="#E74C3C" Height="45" Click="LogoutButton_Click"/>
        </StackPanel>
    </Grid>
</Page>