<Page x:Class="MazeCore.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource MainMenuTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.ColumnDefinitions>
            <!-- Ліва бічна панель навігації -->
            <ColumnDefinition Width="260"/>
            <!-- Основний вміст -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- === ЛІВА НАВІГАЦІЙНА ПАНЕЛЬ === -->
        <Border Grid.Column="0" Background="{DynamicResource CardBackground}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.18" Color="#000000"/>
            </Border.Effect>
            <DockPanel>
                <!-- Верхня частина: лого + ім'я користувача -->
                <StackPanel DockPanel.Dock="Top" Margin="24,32,24,20">
                    <TextBlock Text="🧩" FontSize="34" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource AppTitle}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock x:Name="WelcomeTextBlock"
                               FontSize="13"
                               Foreground="{DynamicResource SubtleText}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top"
                           Background="{DynamicResource BorderColor}"
                           Margin="16,0"/>

                <!-- Кнопки меню -->
                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,0">

                    <Button Content="{DynamicResource BtnPlay}"
                            Style="{StaticResource MenuNavButtonStyle}"
                            Tag="🎮"
                            Margin="0,0,0,8"
                            Click="GoToGame_Click"/>

                    <Button x:Name="AdminEditorButton"
                            Content="{DynamicResource BtnEditor}"
                            Style="{StaticResource MenuNavButtonStyle}"
                            Tag="✏️"
                            Margin="0,0,0,8"
                            Click="GoToEditor_Click"/>

                    <Button Content="{DynamicResource BtnStats}"
                            Style="{StaticResource MenuNavButtonStyle}"
                            Tag="📊"
                            Margin="0,0,0,8"
                            Click="GoToStats_Click"/>

                    <Button Content="{DynamicResource BtnSettings}"
                            Style="{StaticResource MenuNavButtonStyle}"
                            Tag="⚙️"
                            Margin="0,0,0,8"
                            Click="GoToSettings_Click"/>
                </StackPanel>

                <!-- Кнопка виходу — внизу панелі -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,16">
                    <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,12"/>
                    <Button Content="{DynamicResource BtnLogout}"
                            Style="{StaticResource DangerButtonStyle}"
                            Height="40"
                            Click="LogoutButton_Click"/>
                </StackPanel>

                <!-- Заглушка, щоб DockPanel заповнювала простір -->
                <Grid/>
            </DockPanel>
        </Border>

        <!-- === ОСНОВНИЙ ВМІСТ (права частина) === -->
        <Grid Grid.Column="1" Margin="30,30,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{DynamicResource MainMenuTitle}"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource AppForeground}"/>
                <TextBlock Text="{DynamicResource MainMenuSubtitle}"
                           FontSize="14"
                           Foreground="{DynamicResource SubtleText}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Плитки швидкого запуску -->
            <UniformGrid Grid.Row="1" Rows="2" Columns="2">
                <!-- Плитка: Грати -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,12" Cursor="Hand"
                        MouseLeftButtonUp="TileGame_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🎮" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource BtnPlay}"
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AppForeground}"/>
                        <TextBlock Text="{DynamicResource TilePlayDesc}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SubtleText}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="10,6,10,0"/>
                    </StackPanel>
                </Border>

                <!-- Плитка: Статистика -->
                <Border Style="{StaticResource CardStyle}" Margin="12,0,0,12" Cursor="Hand"
                        MouseLeftButtonUp="TileStats_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource BtnStats}"
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AppForeground}"/>
                        <TextBlock Text="{DynamicResource TileStatsDesc}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SubtleText}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="10,6,10,0"/>
                    </StackPanel>
                </Border>

                <!-- Плитка: Редактор (тільки для адмінів) -->
                <Border x:Name="AdminTileBorder"
                        Style="{StaticResource CardStyle}" Margin="0,12,12,0" Cursor="Hand"
                        MouseLeftButtonUp="TileEditor_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="✏️" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource BtnEditor}"
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AppForeground}"/>
                        <TextBlock Text="{DynamicResource TileEditorDesc}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SubtleText}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="10,6,10,0"/>
                    </StackPanel>
                </Border>

                <!-- Плитка: Налаштування -->
                <Border Style="{StaticResource CardStyle}" Margin="12,12,0,0" Cursor="Hand"
                        MouseLeftButtonUp="TileSettings_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource BtnSettings}"
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AppForeground}"/>
                        <TextBlock Text="{DynamicResource TileSettingsDesc}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SubtleText}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="10,6,10,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Grid>
</Page>