<Page x:Class="MazeCore.Views.MazeEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource EditorTitle}">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Ліва панель -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="15">
            <StackPanel>
                <TextBlock Text="{DynamicResource ParamsLabel}" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource AppForeground}"/>

                <TextBlock Text="{DynamicResource MazeNameLabel}" Foreground="{DynamicResource SubtleText}" Margin="0,0,0,5"/>
                <TextBox x:Name="MazeNameTextBox" Height="35" Margin="0,0,0,15" Style="{StaticResource ThemedTextBoxStyle}"/>

                <TextBlock Text="{DynamicResource WidthLabel}" Foreground="{DynamicResource SubtleText}" Margin="0,0,0,5"/>
                <TextBox x:Name="WidthTextBox" Text="21" Height="35" Margin="0,0,0,15" Style="{StaticResource ThemedTextBoxStyle}"/>

                <TextBlock Text="{DynamicResource HeightLabel}" Foreground="{DynamicResource SubtleText}" Margin="0,0,0,5"/>
                <TextBox x:Name="HeightTextBox" Text="21" Height="35" Margin="0,0,0,20" Style="{StaticResource ThemedTextBoxStyle}"/>

                <TextBlock x:Name="StatusTextBlock" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <Button Content="{DynamicResource BtnGenerate}" Style="{StaticResource PrimaryButtonStyle}" 
                        Height="45" Margin="0,0,0,15" Click="GenerateButton_Click"/>

                <Button x:Name="SaveButton" Content="{DynamicResource BtnSaveMaze}" Style="{StaticResource PrimaryButtonStyle}" 
                        Background="{DynamicResource SuccessColor}" Height="45" Margin="0,0,0,20" IsEnabled="False" Click="SaveButton_Click"/>

                <Button Content="{DynamicResource BtnBack}" Style="{StaticResource LinkButtonStyle}" 
                        Height="30" Click="BackButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Права панель з канвасом -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,15,15,15">
            <Viewbox>
                <UniformGrid x:Name="MazeCanvas" Background="Gray"/>
            </Viewbox>
        </Border>
    </Grid>
</Page>