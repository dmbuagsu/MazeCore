<Page x:Class="MazeCore.Views.MazeEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Редактор лабіринтів">

    <Grid Background="#F5F6FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" Margin="10" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel Margin="15">
                <TextBlock Text="Параметри" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333"/>

                <TextBlock Text="Назва лабіринту:" Foreground="#666" Margin="0,0,0,5"/>
                <TextBox x:Name="MazeNameTextBox" Height="30" Margin="0,0,0,10" Padding="3"/>

                <TextBlock Text="Ширина (клітинок):" Foreground="#666" Margin="0,0,0,5"/>
                <TextBox x:Name="WidthTextBox" Text="21" Height="30" Margin="0,0,0,10" Padding="3"/>

                <TextBlock Text="Висота (клітинок):" Foreground="#666" Margin="0,0,0,5"/>
                <TextBox x:Name="HeightTextBox" Text="21" Height="30" Margin="0,0,0,20" Padding="3"/>

                <TextBlock x:Name="StatusTextBlock" Foreground="Red" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <Button Content="ЗГЕНЕРУВАТИ" Style="{StaticResource PrimaryButtonStyle}" 
                        Height="40" Margin="0,0,0,10" Click="GenerateButton_Click"/>

                <Button x:Name="SaveButton" Content="ЗБЕРЕГТИ В БАЗУ" Style="{StaticResource PrimaryButtonStyle}" 
                        Background="#4CD137" Height="40" Margin="0,0,0,20" IsEnabled="False" Click="SaveButton_Click"/>

                <Button Content="Назад в меню" Background="Transparent" Foreground="#0078D7" 
                        BorderThickness="0" Cursor="Hand" Click="BackButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" Margin="0,10,10,10" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>

            <Viewbox Margin="20">
                <UniformGrid x:Name="MazeCanvas" Background="Gray"/>
            </Viewbox>
        </Border>
    </Grid>
</Page>