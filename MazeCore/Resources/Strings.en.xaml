<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- General -->
    <sys:String x:Key="AppTitle">MazeCore</sys:String>

    <!-- WelcomePage -->
    <sys:String x:Key="WelcomeSubtitle">Maze Generator and Pathfinder</sys:String>
    <sys:String x:Key="BtnLogin">SIGN IN</sys:String>
    <sys:String x:Key="BtnCreateAccount">CREATE ACCOUNT</sys:String>

    <!-- LoginPage -->
    <sys:String x:Key="LoginTitle">Sign In</sys:String>
    <sys:String x:Key="LoginLabel">Username:</sys:String>
    <sys:String x:Key="PasswordLabel">Password:</sys:String>
    <sys:String x:Key="BtnSignIn">SIGN IN</sys:String>
    <sys:String x:Key="BtnGoToRegister">Don't have an account? Register</sys:String>

    <!-- RegisterPage -->
    <sys:String x:Key="RegisterTitle">Registration</sys:String>
    <sys:String x:Key="FullNameLabel">Full Name:</sys:String>
    <sys:String x:Key="LoginInputLabel">Username:</sys:String>
    <sys:String x:Key="PasswordInputLabel">Password (min. 4 chars):</sys:String>
    <sys:String x:Key="ConfirmPasswordLabel">Confirm Password:</sys:String>
    <sys:String x:Key="BtnSignUp">REGISTER</sys:String>
    <sys:String x:Key="BtnBackToLogin">Back to Sign In</sys:String>

    <!-- MainMenuPage -->
    <sys:String x:Key="MainMenuTitle">Main Menu</sys:String>
    <sys:String x:Key="BtnPlay">Play (Pathfinder)</sys:String>
    <sys:String x:Key="BtnEditor">Editor (Admin)</sys:String>
    <sys:String x:Key="BtnStats">Statistics</sys:String>
    <sys:String x:Key="BtnSettings">Settings</sys:String>
    <sys:String x:Key="BtnLogout">Logout</sys:String>

    <!-- GamePage -->
    <sys:String x:Key="GameTitle">Maze Solver</sys:String>
    <sys:String x:Key="SelectMazeLabel">Select maze:</sys:String>
    <sys:String x:Key="BtnQuickGame">Quick Game (new)</sys:String>
    <sys:String x:Key="BtnSolveBFS">Solve (BFS)</sys:String>
    <sys:String x:Key="BtnClearPath">Clear Path</sys:String>
    <sys:String x:Key="TimerLabel">Time:</sys:String>
    <sys:String x:Key="PathLengthLabel">Path length:</sys:String>
    <sys:String x:Key="ComplexityLabel">Complexity:</sys:String>
    <sys:String x:Key="BtnBackMenu">Back to Menu</sys:String>

    <!-- StatisticsPage -->
    <sys:String x:Key="StatsTitle">Maze Database</sys:String>
    <sys:String x:Key="BtnSearch">Search</sys:String>
    <sys:String x:Key="BtnSort">Sort</sys:String>
    <sys:String x:Key="BtnRefresh">Refresh</sys:String>
    <sys:String x:Key="BtnDeleteMaze">Delete</sys:String>
    <sys:String x:Key="BtnRenameMaze">Rename</sys:String>
    <sys:String x:Key="BtnBack">Back</sys:String>

    <!-- MazeEditorPage -->
    <sys:String x:Key="EditorTitle">Maze Editor</sys:String>
    <sys:String x:Key="ParamsLabel">Parameters</sys:String>
    <sys:String x:Key="MazeNameLabel">Maze Name:</sys:String>
    <sys:String x:Key="WidthLabel">Width (cells):</sys:String>
    <sys:String x:Key="HeightLabel">Height (cells):</sys:String>
    <sys:String x:Key="BtnGenerate">GENERATE</sys:String>
    <sys:String x:Key="BtnSaveMaze">SAVE TO DATABASE</sys:String>

    <!-- SettingsPage -->
    <sys:String x:Key="SettingsTitle">Settings</sys:String>
    <sys:String x:Key="ThemeLabel">Theme:</sys:String>
    <sys:String x:Key="LightThemeOption">Light</sys:String>
    <sys:String x:Key="DarkThemeOption">Dark</sys:String>
    <sys:String x:Key="LanguageLabel">Interface Language:</sys:String>
    <sys:String x:Key="BtnSaveSettings">Save Settings</sys:String>

</ResourceDictionary>
